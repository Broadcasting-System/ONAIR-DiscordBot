# ONAIR Discord 봇 설정 — 이 파일을 .env 로 복사한 뒤 값을 채우세요.

# Discord 개발자 포털 > 봇 > 토큰
DISCORD_BOT_TOKEN=여기에_봇_토큰

# 명령을 동기화할 길드(서버) ID  (BSSM 방송부)
DISCORD_GUILD_ID=1523998745078005831

# ONAIR 서버 API 주소.
#  - 봇을 ONAIR 서버와 같은 PC에서 돌리면: http://127.0.0.1:8000/api
#  - 다른 PC에서 돌리면: 서버의 Tailscale IP로. 예) http://100.xx.xx.xx:8000/api
ONAIR_API=http://127.0.0.1:8000/api
