# ONAIR Discord 봇 설정 — 이 파일을 .env 로 복사한 뒤 값을 채우세요.

# Discord 개발자 포털 > 봇 > 토큰
DISCORD_BOT_TOKEN=여기에_봇_토큰

# 명령을 동기화할 길드(서버) ID  (BSSM 방송부)
DISCORD_GUILD_ID=1523998745078005831

# ONAIR 서버 API 주소.
#  - 봇을 ONAIR 서버와 같은 PC에서 돌리면: http://127.0.0.1:8000/api
#  - 다른 PC에서 돌리면: 서버의 Tailscale IP로. 예) http://100.xx.xx.xx:8000/api
ONAIR_API=http://127.0.0.1:8000/api

# --- ChatOps(#chatops 자연어 제어) — 선택. 비우면 슬래시 명령만 동작 ---
# Groq API 키(https://console.groq.com). 있으면 #chatops 자연어 제어가 켜진다.
# ※ 키를 넣으면 Discord 개발자 포털 > Bot > "MESSAGE CONTENT INTENT"도 반드시 켜야 함.
GROQ_API_KEY=
# 사용할 모델(기본값 권장). tool calling 지원 모델이어야 함.
GROQ_MODEL=llama-3.3-70b-versatile
